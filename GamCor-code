import cv2
import numpy as np
import os
from google.colab import drive
import glob

drive.mount('/content/drive')

SOURCE_BASE = '/content/drive/MyDrive/SkripsiOASYS/dataset_lengkap' 
DEST_BASE   = '/content/drive/MyDrive/SkripsiOASYS/dataset gamma correction/benar 0,8' 

CLASSES = ['Ot', 'no_OT']

GAMMA = 0.8   # Contoh: 0.8, 1.2, 1.5, dll.

CLASSES = ['OT', 'no_OT']

def gamma_correction(image, gamma):
    """
    Menerapkan gamma correction pada citra (format BGR atau grayscale).
    Menggunakan lookup table (LUT) untuk efisiensi.
    """
    inv_gamma = 1.0 / gamma
    table = np.array([(i / 255.0) ** inv_gamma * 255 for i in range(256)]).astype("uint8")
    return cv2.LUT(image, table)

for cls in CLASSES:
    src_dir = os.path.join(SOURCE_BASE, cls)
    dst_dir = os.path.join(DEST_BASE, cls)
    if not os.path.exists(dst_dir):
        os.makedirs(dst_dir)

    # Cari file gambar
    extensions = ('*.jpg', '*.jpeg', '*.png', '*.bmp')
    image_files = []
    for ext in extensions:
        image_files.extend(glob.glob(os.path.join(src_dir, ext)))
        image_files.extend(glob.glob(os.path.join(src_dir, ext.upper())))

    if not image_files:
        print(f"Tidak ditemukan gambar di {src_dir}")
        continue

    print(f"Memproses kelas {cls}: {len(image_files)} gambar dengan gamma = {GAMMA}")

    for img_path in image_files:
        try:
            # Baca gambar (format BGR)
            img = cv2.imread(img_path)
            if img is None:
                print(f"Gagal membaca: {img_path}")
                continue

            # Terapkan gamma correction
            img_gamma = gamma_correction(img, GAMMA)

            # Simpan hasil
            filename = os.path.basename(img_path)
            save_path = os.path.join(dst_dir, filename)
            cv2.imwrite(save_path, img_gamma)
            print(f"Tersimpan: {save_path}")

        except Exception as e:
            print(f"Error pada {img_path}: {e}")

print(f"\nProses selesai. Hasil gamma correction (gamma={GAMMA}) disimpan di {DEST_BASE}")
